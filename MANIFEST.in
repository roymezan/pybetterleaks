include LICENSE
include README.md
include pyproject.toml
include setup.py

recursive-include bridge *.go go.mod go.sum
recursive-include docs *.md
recursive-include e2e Dockerfile *.md *.py *.sh
recursive-include e2e/fixtures *
recursive-include python/pybetterleaks *.py py.typed
recursive-include scripts *.py *.sh
recursive-include tests *.py

recursive-exclude python/pybetterleaks/native *.dll *.dylib *.h *.so
prune build
prune dist
prune wheelhouse
